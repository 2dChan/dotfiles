{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "agent": {
    "plan": {
      "model": "openai/gpt-5.6-sol-fast"
    },
    "build": {
      "model": "openai/gpt-5.6-terra-pro"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    }
  }
}
