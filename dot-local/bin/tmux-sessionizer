#!/bin/sh

if [ $# -eq 1 ]; then
    selected=$1
else
    selected=$( (find ~/Documents/Projects -mindepth 1 -maxdepth 1 -type d; if [ -d ~/.dotfiles ]; then echo $HOME/.dotfiles; fi) | fzf )
fi

if [ -z "$selected" ]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
    tmux new-window -t "$selected_name" -c "$selected"
    tmux new-window -t "$selected_name" -c "$selected" "opencode"
    tmux select-window -t "$selected_name:0"
fi

if [ -n "$TMUX" ]; then
    tmux switch-client -t "$selected_name"
else
    tmux attach-session -t "$selected_name"
fi
