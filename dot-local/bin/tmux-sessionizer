#!/bin/sh

config_file="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/paths.txt"

emit_extra_paths() {
    [ -f "$config_file" ] || return 0

    while IFS= read -r p || [ -n "$p" ]; do
        case "$p" in
            "\$HOME/"*) p="$HOME/${p#\$HOME/}" ;;
        esac

        case "$p" in
            */\*)
                p="${p%/*}"
                [ -d "$p" ] && find "$p" -mindepth 1 -maxdepth 1 -type d ! -name '.*'
                ;;
            *)
                [ -d "$p" ] && printf '%s\n' "$p"
                ;;
        esac
    done < "$config_file"
}

if [ $# -eq 1 ]; then
    selected=$1
else
    selected=$(emit_extra_paths | awk '!seen[$0]++' | sort -fV | fzf)
fi

if [ -z "$selected" ]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
    tmux new-window -t "$selected_name" -c "$selected"
    tmux new-window -t "$selected_name" -c "$selected" "opencode"
    tmux select-window -t "$selected_name:1"
fi

if [ -n "$TMUX" ]; then
    tmux switch-client -t "$selected_name"
else
    tmux attach-session -t "$selected_name"
fi
